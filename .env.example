SPOTIFY_AUTHORIZE_URL=
SPOTIFY_TOKEN_URL=
SPOTIFY_API_BASE_URL=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Inclua os escopos de identidade junto aos demais: user-read-email user-read-private
SPOTIFY_SCOPE=user-read-email user-read-private user-read-currently-playing user-top-read

# URL do frontend (sem barra no final).
FRONTEND_URL=https://take-me.arthur-nicolas.com.br

# Origens permitidas no CORS (sem barra no final).
# Inclua localhost no dev para o callback redirecionar de volta ao front local.
CORS_ALLOWED_ORIGINS=https://take-me.arthur-nicolas.com.br,http://localhost:5173

# Callback do Spotify (deve estar cadastrado no Spotify Developer Dashboard).
SPOTIFY_REDIRECT_URI=https://api-take-me.arthur-nicolas.com.br/auth/spotify/callback

# Dev local (Spotify exige 127.0.0.1, não localhost):
# FRONTEND_URL=http://127.0.0.1:5173
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/spotify/callback

